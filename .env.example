LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_BOT_NAME=
# 群組/聊天室是否必須 @Bot 才回應（true=需要@, false=不用@也回）
LINE_GROUP_REQUIRE_MENTION=true

# 應用綁定地址
# 0.0.0.0 = 監聽所有網卡（推薦，可用區網 IP 存取）
# 127.0.0.1 = 只允許本機 localhost 存取
APP_HOST=0.0.0.0
APP_PORT=8000
# 開發模式熱重載（true=程式改動自動重啟；正式環境建議 false）
APP_RELOAD=true
# Windows 本機執行時啟用托盤 UI 視窗（含角色下拉選單）
TRAY_UI_ENABLED=false

LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_EXE_PATH=
LM_STUDIO_CHAT_MODEL=qwen/qwen3.5-9b
LM_STUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
# 主回答流程的 LLM timeout 秒數
LM_STUDIO_TIMEOUT_SECONDS=90
# Response Guard 專用 timeout；失敗時直接放行草稿，避免卡住主回覆
LM_STUDIO_GUARD_TIMEOUT_SECONDS=20
# 單次回覆最大 tokens；越大通常越慢
LM_STUDIO_MAX_TOKENS=1024
# 溫度（越高越發散，越低越穩定）
LM_STUDIO_TEMPERATURE=0.7

SQLITE_PATH=data/app.db
# 每個 session 保留多少輪近期對話上下文
SESSION_MAX_TURNS=8
# 是否啟用 session 長期摘要記憶（true=啟用，false=停用）
SESSION_MEMORY_ENABLED=true
# 累積多少則新訊息後觸發一次記憶摘要
SESSION_MEMORY_TRIGGER_MESSAGES=6
# 每次摘要最多抓幾則新訊息窗口
SESSION_MEMORY_WINDOW_MESSAGES=12
# 記憶摘要最大字數
SESSION_MEMORY_MAX_CHARS=1200
# 是否允許程式碼撰寫/修改/除錯請求（false=直接婉拒）
CODING_ASSISTANCE_ENABLED=false
# 回答品質守門（true=啟用，false=停用）
RESPONSE_GUARD_ENABLED=true
# 守門未通過時是否自動重寫回答
RESPONSE_GUARD_REWRITE_ENABLED=true
# Guard 僅在輸入總長度不超過此值時執行，避免長文審核拖慢回覆
RESPONSE_GUARD_MAX_INPUT_CHARS=4000
# 角色扮演啟用時是否略過 guard，避免角色語氣被誤判重寫
RESPONSE_GUARD_SKIP_WHEN_PERSONA=true
# 角色扮演功能開關（true=啟用，false=停用）
ROLEPLAY_ENABLED=false
# 可自訂角色描述，例如：你現在扮演溫柔的虛擬情人，語氣貼心且有界線。
ROLEPLAY_PERSONA_PROMPT=
# 有 persona 時是否弱化預設助理口吻，優先遵從角色設定
ROLEPLAY_PRIORITY_MODE=true
# 傳給模型的上下文最大字數，越大越完整但可能越慢
MAX_CONTEXT_CHARS=6000
LOG_LEVEL=INFO
SYSTEM_PROMPT=你是 LINE 聊天助理，請使用繁體中文回答，內容簡潔、清楚且可執行。若資訊不足，請誠實說明限制。

# RAG 開關（true=啟用本地知識庫檢索；false=僅靠模型與對話上下文）
# 建議：常問你自己的文件/SOP 時設 true；一般閒聊可設 false
# 啟用後請先重建索引：uv run python scripts/ingest_knowledge.py
RAG_ENABLED=false
KNOWLEDGE_DIR=data/knowledge
RAG_TOP_K=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100

# 線上搜尋提供者：duckduckgo / perplexity
WEB_SEARCH_PROVIDER=duckduckgo
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# 本地模型不確定時，是否啟用外部 OpenAI-compatible 模型備援
EXTERNAL_LLM_FALLBACK_ENABLED=false
EXTERNAL_LLM_BASE_URL=https://openrouter.ai/api/v1
EXTERNAL_LLM_API_KEY=
EXTERNAL_LLM_MODELS=openai/gpt-5-mini,google/gemini-2.5-flash
EXTERNAL_LLM_TIMEOUT_SECONDS=45

# 圖片 OCR 開關（true=啟用，false=停用）
# 啟用後，LINE 圖片訊息會先 OCR，再交給既有回答流程
IMAGE_OCR_ENABLED=true

# 檔案解析開關（true=啟用，false=停用）
# 啟用後，LINE 檔案訊息會先抽取文字，再交給既有回答流程
FILE_PARSER_ENABLED=true

# Agent（工具呼叫 ReAct loop）總開關
AGENT_ENABLED=true
# 第一輪若沒有 tool_call 就直接回答，減少多輪延遲
AGENT_FAST_MODE=true
# 遇到「不確定」時是否自動補做 web_search
AGENT_AUTO_SEARCH=false
# 最多工具輪數，建議 1-2；數字越大越慢
AGENT_MAX_TOOL_ROUNDS=2

# 假訊息查證功能開關（true=啟用，false=停用）
# 啟用後，系統會先判斷訊息是否適合走查證流程
FACTCHECK_ENABLED=true
# 最多對幾個主張發出搜尋（建議 1-3，愈多愈慢）
FACTCHECK_MAX_SEARCH_QUERIES=2
# 每次搜尋保留幾筆結果（建議 3-5）
FACTCHECK_MAX_RESULTS_PER_QUERY=4
